properties([
  disableConcurrentBuilds(),
  buildDiscarder(logRotator(numToKeepStr: '10', daysToKeepStr: '30'))
])

timeout(time: 1, unit: 'HOURS') {
  def cudas = ['12.9.1', '13.1.1'].collectEntries { CUDA ->
    [CUDA, { ->
      buildPod(tag: CUDA,
        context: 'ci',
        buildArgs: "--build-arg CUDA=$CUDA",
        gpus: 1,
        gpuType: 'a100') {
        withEnv([
          "HOME=$WORKSPACE",
          "PY_CUDA_EXTRA=cuda${CUDA.split('\\.')[0]}-local",
          "CMAKE_ARGS=-DJAX_FINUFFT_USE_CUDA=ON -DCMAKE_CUDA_ARCHITECTURES=native"
        ]) {
                    stage('Build') {
                            sh '''
                                uv sync
                            '''
                    }
                    stage('CPU Tests') {
                        withEnv(["JAX_PLATFORMS=cpu"]) {
                            sh '''
                                export OMP_NUM_THREADS=$PARALLEL
                                uv run --extra test pytest -n 8
                            '''
                        }
                    }
                    stage('GPU Tests') {
                        withEnv(["JAX_PLATFORMS=cuda"]) {
                            // TODO: add "-n 8", but GPU kernels don't seem to be thread-safe
                            sh '''
                                export OMP_NUM_THREADS=$PARALLEL
                                uv run --extra test --extra ${PY_CUDA_EXTRA} pytest -vs
                            '''
                        }
                    }
                    stage('Free-threaded GPU Tests') {
                        withEnv(["JAX_PLATFORMS=cuda"]) {
                            sh '''
                                export OMP_NUM_THREADS=$PARALLEL
                                uv run -p 3.13t --extra test --extra ${PY_CUDA_EXTRA} pytest -vs
                            '''
                        }
                    }
        }
      }
    }]
  }
  parallel cudas
}
